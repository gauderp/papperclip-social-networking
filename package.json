{
  "name": "@gauderp/social-networking",
  "version": "0.1.0",
  "type": "module",
  "description": "Gerencia conexoes e publicacoes em redes sociais (LinkedIn primeiro).",
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": ["paperclip", "plugin", "connector"],
  "author": "Gaud ERP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gauderp/papperclip-social-networking.git"
  },
  "bugs": {
    "url": "https://github.com/gauderp/papperclip-social-networking/issues"
  },
  "homepage": "https://github.com/gauderp/papperclip-social-networking#readme",
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.517.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
